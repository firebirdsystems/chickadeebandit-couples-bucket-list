{
  "manifest": {
    "id": "couples-bucket-list",
    "name": "Couple's Bucket List",
    "version": "1.0.0",
    "description": "A shared wishlist of experiences — travel, food, skills, milestones — that you want to do together.",
    "entrypoint": "index.html",
    "runtime": "static",
    "category": "couple",
    "tags": [
      "couples"
    ],
    "data_access": {
      "reads": [
        "family.members"
      ],
      "writes": []
    },
    "permissions": {
      "default_audience": "adults",
      "requires_approval": false
    },
    "storage": "db",
    "icon": "🪣",
    "nav": {
      "label": "Bucket List"
    }
  },
  "migrations": [
    {
      "version": 1,
      "sql": "CREATE TABLE IF NOT EXISTS partner_config (\n  member_id TEXT NOT NULL,\n  household_id UUID NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  partner_id TEXT NOT NULL,\n  PRIMARY KEY (member_id, household_id)\n);\n\nCREATE TABLE IF NOT EXISTS bucket_items (\n  id TEXT PRIMARY KEY,\n  household_id UUID NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  created_by TEXT NOT NULL,\n  title TEXT NOT NULL,\n  notes TEXT,\n  category TEXT NOT NULL DEFAULT 'other',\n  done_at TEXT,\n  done_note TEXT,\n  photo_id TEXT,\n  created_at TEXT NOT NULL\n);"
    }
  ],
  "files": {
    "index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <base href=\"/run/couples-bucket-list/\" />\n  <title>Couple's Bucket List</title>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: var(--hub-font, system-ui, sans-serif);\n      font-size: var(--hub-font-size, 15px);\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n      min-height: 100vh;\n    }\n\n    .view { display: none; }\n    .view.active { display: block; }\n\n    /* ── App header ── */\n    .app-header {\n      display: flex; align-items: center; justify-content: space-between;\n      padding: 16px 20px 0;\n    }\n    .app-header-left { display: flex; align-items: center; gap: 8px; }\n    .app-header .icon { font-size: 1.3rem; }\n    .app-header h1 { font-size: 1.25rem; font-weight: 700; }\n\n    /* ── Setup view ── */\n    .setup-wrap {\n      display: flex; flex-direction: column; align-items: center;\n      padding: 48px 20px; min-height: 80vh; justify-content: center;\n    }\n    .setup-card {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 32px; max-width: 420px; width: 100%; text-align: center;\n    }\n    .setup-icon { font-size: 2.5rem; margin-bottom: 16px; }\n    .setup-card h2 { font-size: 1.2rem; font-weight: 700; margin-bottom: 6px; }\n    .setup-card .setup-desc { color: var(--hub-text-muted, #6b7280); font-size: 0.9rem; margin-bottom: 24px; }\n    .setup-card .pick-label { font-weight: 600; margin-bottom: 12px; text-align: left; display: block; }\n    .member-list { margin-bottom: 20px; }\n    .member-option {\n      display: flex; align-items: center; gap: 10px; padding: 10px 12px;\n      border: 1px solid var(--hub-border, #e5e7eb); border-radius: var(--hub-radius, 6px);\n      cursor: pointer; margin-bottom: 6px; transition: border-color .15s, background .15s; text-align: left;\n    }\n    .member-option input[type=\"radio\"] { accent-color: var(--hub-primary, #6366f1); }\n    .member-option:has(input:checked) {\n      border-color: var(--hub-primary, #6366f1);\n      background: color-mix(in srgb, var(--hub-primary, #6366f1) 6%, transparent);\n    }\n    .member-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: #fff; flex-shrink: 0; }\n    .member-name { font-weight: 500; font-size: 0.95rem; }\n\n    /* ── Progress bar ── */\n    .progress-row {\n      display: flex; align-items: center; gap: 12px;\n      padding: 12px 20px 0;\n    }\n    .progress-bar-wrap { flex: 1; height: 6px; background: var(--hub-border, #e5e7eb); border-radius: 999px; overflow: hidden; }\n    .progress-bar-fill { height: 100%; background: var(--hub-primary, #6366f1); border-radius: 999px; transition: width .4s; }\n    .progress-label { font-size: 0.82rem; color: var(--hub-text-muted, #6b7280); white-space: nowrap; }\n\n    /* ── Content ── */\n    .content { padding: 14px 20px 20px; }\n\n    /* ── Category sections ── */\n    .category-section { margin-bottom: 20px; }\n    .category-heading {\n      font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em;\n      color: var(--hub-text-muted, #6b7280); margin-bottom: 8px;\n    }\n    .items-list { display: flex; flex-direction: column; gap: 8px; }\n\n    /* ── Item cards ── */\n    .item-card {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 12px 14px;\n    }\n    .item-header { display: flex; align-items: flex-start; gap: 8px; }\n    .item-check {\n      width: 18px; height: 18px; border: 2px solid var(--hub-border, #e5e7eb);\n      border-radius: 4px; flex-shrink: 0; cursor: pointer; margin-top: 2px;\n      display: flex; align-items: center; justify-content: center;\n      transition: background .15s, border-color .15s;\n    }\n    .item-check.done { background: var(--hub-primary, #6366f1); border-color: var(--hub-primary, #6366f1); color: #fff; font-size: 0.7rem; }\n    .item-title { font-weight: 500; font-size: 0.95rem; flex: 1; line-height: 1.4; }\n    .item-title.done { text-decoration: line-through; opacity: .6; }\n    .item-notes { font-size: 0.85rem; color: var(--hub-text-muted, #6b7280); margin-top: 5px; white-space: pre-wrap; word-break: break-word; }\n    .item-done-note { font-size: 0.85rem; color: var(--hub-text-muted, #6b7280); margin-top: 5px; font-style: italic; }\n    .item-photo { margin-top: 8px; max-width: 100%; border-radius: var(--hub-radius, 6px); max-height: 200px; object-fit: cover; }\n    .item-meta { margin-top: 6px; font-size: 0.78rem; color: var(--hub-text-muted, #6b7280); }\n\n    /* ── Completed section toggle ── */\n    .completed-toggle {\n      background: transparent; border: none; cursor: pointer;\n      color: var(--hub-text-muted, #6b7280); font-size: 0.9rem; font-weight: 500;\n      display: flex; align-items: center; gap: 6px; padding: 8px 0; margin-bottom: 8px;\n    }\n    .completed-toggle:hover { color: var(--hub-text, #111827); }\n\n    /* ── Empty state ── */\n    .empty-state { text-align: center; padding: 40px 20px; color: var(--hub-text-muted, #6b7280); }\n    .empty-state .empty-icon { font-size: 2rem; margin-bottom: 12px; }\n    .empty-state p { font-size: 0.95rem; }\n\n    /* ── Buttons ── */\n    .btn-primary {\n      background: var(--hub-primary, #6366f1); color: var(--hub-primary-fg, #fff);\n      border: none; border-radius: var(--hub-radius, 6px);\n      padding: 10px 20px; font-size: 0.95rem; font-weight: 600; cursor: pointer;\n      transition: opacity .15s; display: inline-flex; align-items: center; gap: 6px;\n    }\n    .btn-primary:hover:not(:disabled) { opacity: .85; }\n    .btn-primary:disabled { opacity: .5; cursor: not-allowed; }\n    .btn-secondary {\n      background: transparent; color: var(--hub-text, #111827);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      padding: 10px 20px; font-size: 0.95rem; font-weight: 500; cursor: pointer;\n    }\n    .btn-secondary:hover { background: var(--hub-bg, #f9fafb); }\n    .btn-icon {\n      background: transparent; border: none; cursor: pointer;\n      color: var(--hub-text-muted, #6b7280); padding: 6px;\n      border-radius: var(--hub-radius, 4px); font-size: 1rem; line-height: 1;\n    }\n    .btn-icon:hover { color: var(--hub-text, #111827); background: var(--hub-bg, #f9fafb); }\n\n    /* ── Modal ── */\n    .modal-backdrop {\n      position: fixed; inset: 0; background: rgba(0,0,0,.45);\n      display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 20px;\n    }\n    .modal {\n      background: var(--hub-surface, #fff); border-radius: var(--hub-radius, 8px);\n      padding: 24px; width: 100%; max-width: 460px;\n      box-shadow: 0 8px 32px rgba(0,0,0,.18); max-height: 90vh; overflow-y: auto;\n    }\n    .modal h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 16px; }\n    .form-group { margin-bottom: 14px; }\n    .form-group label { display: block; font-weight: 500; margin-bottom: 5px; font-size: 0.9rem; }\n    .form-group input, .form-group textarea, .form-group select {\n      width: 100%; padding: 9px 12px;\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n      font-family: inherit; font-size: inherit;\n    }\n    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: 2px solid var(--hub-primary, #6366f1); outline-offset: 1px; }\n    .form-group textarea { resize: vertical; min-height: 80px; }\n    .upload-area {\n      border: 2px dashed var(--hub-border, #e5e7eb); border-radius: var(--hub-radius, 6px);\n      padding: 16px; text-align: center; cursor: pointer; font-size: 0.85rem; color: var(--hub-text-muted, #6b7280);\n    }\n    .upload-area:hover { border-color: var(--hub-primary, #6366f1); }\n    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px; }\n  </style>\n</head>\n<body>\n\n  <!-- ── Setup view ── -->\n  <div id=\"view-setup\" class=\"view\">\n    <div class=\"setup-wrap\">\n      <div class=\"setup-card\">\n        <div class=\"setup-icon\">🪣</div>\n        <h2>Couple's Bucket List</h2>\n        <p class=\"setup-desc\">A shared wishlist of experiences — travel, food, skills, and milestones — for just the two of you.</p>\n        <span class=\"pick-label\">Who is your partner?</span>\n        <div id=\"setup-members\" class=\"member-list\"></div>\n        <button class=\"btn-primary\" style=\"width:100%;justify-content:center\" onclick=\"savePartner()\">Get Started</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- ── Main view ── -->\n  <div id=\"view-main\" class=\"view\">\n    <div class=\"app-header\">\n      <div class=\"app-header-left\">\n        <span class=\"icon\">🪣</span>\n        <h1>Bucket List</h1>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:8px\">\n        <button class=\"btn-icon\" title=\"Change partner\" onclick=\"showSetup()\">⚙️</button>\n        <button class=\"btn-primary\" onclick=\"openAddItem()\">+ Add</button>\n      </div>\n    </div>\n    <div id=\"progress-row\" class=\"progress-row\"></div>\n    <div class=\"content\">\n      <div id=\"active-list\"></div>\n      <div id=\"completed-section\"></div>\n    </div>\n  </div>\n\n  <script type=\"module\">\n    import { esc, initial, memberColor, formatRelativeDate, createFilesHelper } from \"/hub-sdk.js\";\n    import { CATEGORIES, validateItem, categoryLabel, groupByCategory } from \"./logic.js\";\n\n    const CONTEXT = window.__CONTEXT_URL ?? \"\";\n    const DB      = window.__DB_URL      ?? \"\";\n    const ME      = window.__CURRENT_MEMBER ?? null;\n    const APP_ID  = window.__APP_ID ?? \"couples-bucket-list\";\n\n    const files = createFilesHelper(window.__FILES_URL ?? \"\");\n\n    let members  = [];\n    let partner  = null;\n    let items    = [];\n    let modalEl  = null;\n    let completedVisible = false;\n\n    async function db(sql, params = []) {\n      if (!DB) return { rows: [] };\n      const res = await fetch(DB, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ sql, params }),\n      });\n      return res.json();\n    }\n\n    async function loadMembers() {\n      if (!CONTEXT) {\n        members = [\n          { id: \"demo-1\", name: \"Alex\",   role: \"adult\" },\n          { id: \"demo-2\", name: \"Jordan\", role: \"adult\" },\n          { id: \"demo-3\", name: \"Sam\",    role: \"adult\" },\n        ];\n        return;\n      }\n      try {\n        const res = await fetch(`${CONTEXT}?keys=family.members`);\n        members = ((await res.json())[\"family.members\"]) ?? [];\n      } catch { members = []; }\n    }\n\n    async function loadPartner() {\n      if (!ME) return null;\n      const { rows } = await db(\n        \"SELECT partner_id FROM partner_config WHERE member_id = ?\",\n        [ME.id]\n      );\n      return rows.length ? (members.find(m => m.id === rows[0].partner_id) ?? null) : null;\n    }\n\n    async function loadItems() {\n      if (!ME || !partner) {\n        items = [\n          { id: \"d1\", created_by: \"demo-1\", title: \"See the Northern Lights\", notes: \"Iceland or Norway\", category: \"travel\", done_at: null, done_note: null, photo_id: null, created_at: new Date(Date.now() - 86400000).toISOString() },\n          { id: \"d2\", created_by: \"demo-2\", title: \"Take a cooking class together\", notes: \"Italian or Thai\", category: \"skill\", done_at: null, done_note: null, photo_id: null, created_at: new Date(Date.now() - 172800000).toISOString() },\n          { id: \"d3\", created_by: \"demo-1\", title: \"Try omakase sushi\", notes: \"\", category: \"food\", done_at: new Date(Date.now() - 604800000).toISOString(), done_note: \"Amazing experience! 10/10\", photo_id: null, created_at: new Date(Date.now() - 700000000).toISOString() },\n        ];\n        return;\n      }\n      const { rows } = await db(\n        \"SELECT * FROM bucket_items WHERE created_by IN (?, ?) ORDER BY created_at DESC\",\n        [ME.id, partner.id]\n      );\n      items = rows;\n    }\n\n    window.savePartner = async function() {\n      const sel = document.querySelector('#setup-members input[type=\"radio\"]:checked');\n      if (!sel) return;\n      const partnerId = sel.value;\n      const btn = document.querySelector('#view-setup .btn-primary');\n      if (btn) { btn.disabled = true; btn.textContent = \"Saving…\"; }\n      try {\n        if (ME) {\n          await db(\n            `INSERT INTO partner_config (member_id, partner_id) VALUES (?, ?)\n             ON CONFLICT (member_id, household_id) DO UPDATE SET partner_id = EXCLUDED.partner_id`,\n            [ME.id, partnerId]\n          );\n        }\n        partner = members.find(m => m.id === partnerId) ?? null;\n        await loadItems();\n        showMain();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Get Started\"; }\n        throw e;\n      }\n    };\n\n    // ── Modal helpers ─────────────────────────────────────────────────────────\n    function openModal(html) {\n      closeModal();\n      modalEl = document.createElement(\"div\");\n      modalEl.className = \"modal-backdrop\";\n      modalEl.innerHTML = `<div class=\"modal\">${html}</div>`;\n      modalEl.addEventListener(\"click\", e => { if (e.target === modalEl) closeModal(); });\n      document.body.appendChild(modalEl);\n    }\n    window.closeModal = function() { modalEl?.remove(); modalEl = null; };\n\n    // ── Add item ──────────────────────────────────────────────────────────────\n    window.openAddItem = function() {\n      const catOptions = CATEGORIES.map(c =>\n        `<option value=\"${esc(c.value)}\">${esc(c.label)}</option>`\n      ).join(\"\");\n      openModal(`\n        <h3>Add to Bucket List</h3>\n        <div class=\"form-group\">\n          <label>What do you want to do?</label>\n          <input id=\"f-title\" type=\"text\" placeholder=\"e.g. See the Northern Lights\" />\n        </div>\n        <div class=\"form-group\">\n          <label>Category</label>\n          <select id=\"f-category\">${catOptions}</select>\n        </div>\n        <div class=\"form-group\">\n          <label>Notes <span style=\"color:var(--hub-text-muted,#6b7280);font-weight:400\">(optional)</span></label>\n          <textarea id=\"f-notes\" placeholder=\"Details, ideas, where to go…\"></textarea>\n        </div>\n        <div class=\"modal-actions\">\n          <button class=\"btn-secondary\" onclick=\"closeModal()\">Cancel</button>\n          <button class=\"btn-primary\" onclick=\"submitItem()\">Add</button>\n        </div>\n      `);\n      document.getElementById(\"f-title\").focus();\n    };\n\n    window.submitItem = async function() {\n      const titleInput = document.getElementById(\"f-title\");\n      const result = validateItem(titleInput?.value);\n      if (!result.valid) { titleInput?.focus(); return; }\n\n      const btn = modalEl?.querySelector(\".modal-actions .btn-primary\");\n      if (btn) { btn.disabled = true; btn.textContent = \"Adding…\"; }\n      try {\n        if (ME) {\n          await db(\n            \"INSERT INTO bucket_items (id, created_by, title, notes, category, created_at) VALUES (?, ?, ?, ?, ?, ?)\",\n            [crypto.randomUUID(), ME.id, result.trimmed,\n             document.getElementById(\"f-notes\")?.value.trim() ?? \"\",\n             document.getElementById(\"f-category\")?.value ?? \"other\",\n             new Date().toISOString()]\n          );\n          await loadItems();\n        }\n        closeModal();\n        renderItems();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Add\"; }\n        throw e;\n      }\n    };\n\n    // ── Mark done ─────────────────────────────────────────────────────────────\n    window.openMarkDone = function(id) {\n      const item = items.find(i => i.id === id);\n      if (!item) return;\n      const uploadHtml = window.__FILES_URL\n        ? `<div class=\"form-group\">\n             <label>Photo <span style=\"color:var(--hub-text-muted,#6b7280);font-weight:400\">(optional)</span></label>\n             <label class=\"upload-area\" for=\"f-photo\">📷 Tap to attach a photo</label>\n             <input id=\"f-photo\" type=\"file\" accept=\"image/*\" style=\"display:none\" onchange=\"previewPhoto(this)\" />\n             <img id=\"photo-preview\" style=\"display:none;margin-top:8px;max-width:100%;border-radius:var(--hub-radius,6px)\" />\n           </div>`\n        : \"\";\n      openModal(`\n        <h3>Mark as Done 🎉</h3>\n        <p style=\"color:var(--hub-text-muted,#6b7280);margin-bottom:16px;font-size:.9rem\">${esc(item.title)}</p>\n        <div class=\"form-group\">\n          <label>How did it go? <span style=\"color:var(--hub-text-muted,#6b7280);font-weight:400\">(optional)</span></label>\n          <textarea id=\"f-done-note\" placeholder=\"A moment to remember…\"></textarea>\n        </div>\n        ${uploadHtml}\n        <div class=\"modal-actions\">\n          <button class=\"btn-secondary\" onclick=\"closeModal()\">Cancel</button>\n          <button class=\"btn-primary\" onclick=\"confirmDone('${esc(id)}')\">Done! ✓</button>\n        </div>\n      `);\n    };\n\n    window.previewPhoto = function(input) {\n      const file = input.files?.[0];\n      if (!file) return;\n      const preview = document.getElementById(\"photo-preview\");\n      if (!preview) return;\n      preview.src = URL.createObjectURL(file);\n      preview.style.display = \"block\";\n    };\n\n    window.confirmDone = async function(id) {\n      const btn = modalEl?.querySelector(\".modal-actions .btn-primary\");\n      if (btn) { btn.disabled = true; btn.textContent = \"Saving…\"; }\n      try {\n        const doneNote = document.getElementById(\"f-done-note\")?.value.trim() ?? \"\";\n        const photoFile = document.getElementById(\"f-photo\")?.files?.[0];\n        let photoId = null;\n        if (photoFile) {\n          const { id: fid } = await files.upload(photoFile);\n          photoId = fid;\n        }\n        if (ME) {\n          await db(\n            \"UPDATE bucket_items SET done_at = ?, done_note = ?, photo_id = ? WHERE id = ?\",\n            [new Date().toISOString(), doneNote || null, photoId, id]\n          );\n          await loadItems();\n        }\n        closeModal();\n        renderItems();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Done! ✓\"; }\n        throw e;\n      }\n    };\n\n    // ── Toggle completed ──────────────────────────────────────────────────────\n    window.toggleCompleted = function() {\n      completedVisible = !completedVisible;\n      renderItems();\n    };\n\n    // ── Views ─────────────────────────────────────────────────────────────────\n    window.showSetup = function() {\n      const otherAdults = members.filter(m => m.role === \"adult\" && m.id !== (ME?.id ?? \"demo-1\"));\n      const listEl = document.getElementById(\"setup-members\");\n      listEl.innerHTML = otherAdults.map(m => {\n        const color = memberColor(m.id, members);\n        return `<label class=\"member-option\">\n          <input type=\"radio\" name=\"partner\" value=\"${esc(m.id)}\" />\n          <span class=\"member-avatar\" style=\"background:${color}\">${esc(initial(m.name))}</span>\n          <span class=\"member-name\">${esc(m.name)}</span>\n        </label>`;\n      }).join(\"\");\n      if (partner) {\n        const radio = listEl.querySelector(`input[value=\"${CSS.escape(partner.id)}\"]`);\n        if (radio) radio.checked = true;\n      }\n      document.getElementById(\"view-setup\").classList.add(\"active\");\n      document.getElementById(\"view-main\").classList.remove(\"active\");\n    };\n\n    function showMain() {\n      document.getElementById(\"view-setup\").classList.remove(\"active\");\n      document.getElementById(\"view-main\").classList.add(\"active\");\n      renderItems();\n    }\n\n    function renderItems() {\n      const active    = items.filter(i => !i.done_at);\n      const completed = items.filter(i => i.done_at).sort((a,b) => b.done_at.localeCompare(a.done_at));\n      const total     = items.length;\n      const doneCount = completed.length;\n\n      // Progress bar\n      const progressEl = document.getElementById(\"progress-row\");\n      if (total > 0) {\n        const pct = Math.round((doneCount / total) * 100);\n        progressEl.innerHTML = `\n          <div class=\"progress-bar-wrap\"><div class=\"progress-bar-fill\" style=\"width:${pct}%\"></div></div>\n          <span class=\"progress-label\">${doneCount} / ${total} done</span>`;\n      } else {\n        progressEl.innerHTML = \"\";\n      }\n\n      // Active items grouped by category\n      const activeEl = document.getElementById(\"active-list\");\n      if (!active.length) {\n        activeEl.innerHTML = `<div class=\"empty-state\"><div class=\"empty-icon\">🪣</div><p>No items yet — add your first dream!</p></div>`;\n      } else {\n        const groups = groupByCategory(active);\n        activeEl.innerHTML = groups.map(g => `\n          <div class=\"category-section\">\n            <div class=\"category-heading\">${esc(categoryLabel(g.category))}</div>\n            <div class=\"items-list\">${g.items.map(item => renderItemCard(item, false)).join(\"\")}</div>\n          </div>`).join(\"\");\n      }\n\n      // Completed section\n      const compEl = document.getElementById(\"completed-section\");\n      if (!completed.length) { compEl.innerHTML = \"\"; return; }\n      const listHtml = completedVisible\n        ? `<div class=\"items-list\">${completed.map(item => renderItemCard(item, true)).join(\"\")}</div>`\n        : \"\";\n      compEl.innerHTML = `\n        <button class=\"completed-toggle\" onclick=\"toggleCompleted()\">\n          ${completedVisible ? \"▾\" : \"▸\"} Completed (${doneCount})\n        </button>\n        ${listHtml}`;\n    }\n\n    function renderItemCard(item, isDone) {\n      const checkHtml = `<span class=\"item-check${isDone ? \" done\" : \"\"}\" onclick=\"${isDone ? \"\" : `openMarkDone('${esc(item.id)}')`}\" style=\"cursor:${isDone ? \"default\" : \"pointer\"}\">${isDone ? \"✓\" : \"\"}</span>`;\n      const notesHtml  = item.notes ? `<div class=\"item-notes\">${esc(item.notes)}</div>` : \"\";\n      const doneNoteHtml = item.done_note ? `<div class=\"item-done-note\">\"${esc(item.done_note)}\"</div>` : \"\";\n      const photoHtml  = item.photo_id\n        ? `<img class=\"item-photo\" src=\"${esc(files.url(item.photo_id))}\" alt=\"\" loading=\"lazy\" />`\n        : \"\";\n      const metaHtml   = isDone\n        ? `<div class=\"item-meta\">Completed ${formatRelativeDate(item.done_at)}</div>`\n        : `<div class=\"item-meta\">Added ${formatRelativeDate(item.created_at)}</div>`;\n      return `\n        <div class=\"item-card\">\n          <div class=\"item-header\">\n            ${checkHtml}\n            <span class=\"item-title${isDone ? \" done\" : \"\"}\">${esc(item.title)}</span>\n          </div>\n          ${notesHtml}${doneNoteHtml}${photoHtml}${metaHtml}\n        </div>`;\n    }\n\n    // ── Init ──────────────────────────────────────────────────────────────────\n    (async () => {\n      await loadMembers();\n      partner = await loadPartner();\n      if (!partner) {\n        window.showSetup();\n      } else {\n        await loadItems();\n        showMain();\n      }\n    })();\n  </script>\n</body>\n</html>\n",
    "logic.js": "export const CATEGORIES = [\n  { value: \"travel\",    label: \"Travel ✈️\" },\n  { value: \"food\",      label: \"Food & Drink 🍽️\" },\n  { value: \"skill\",     label: \"Learn Together 📚\" },\n  { value: \"milestone\", label: \"Milestone 🎉\" },\n  { value: \"other\",     label: \"Other ✨\" },\n];\n\nexport function validateItem(title) {\n  const trimmed = (title ?? \"\").trim();\n  if (!trimmed) return { valid: false, trimmed: \"\" };\n  if (trimmed.length > 200) return { valid: false, trimmed };\n  return { valid: true, trimmed };\n}\n\nexport function categoryLabel(value) {\n  return CATEGORIES.find(c => c.value === value)?.label ?? value;\n}\n\nexport function groupByCategory(items) {\n  const order = CATEGORIES.map(c => c.value);\n  const map = {};\n  for (const item of items) {\n    const cat = item.category ?? \"other\";\n    if (!map[cat]) map[cat] = [];\n    map[cat].push(item);\n  }\n  return order.filter(k => map[k]?.length).map(k => ({ category: k, items: map[k] }));\n}\n"
  }
}